---

<Layout title="실천불교전국승가회">
  <!-- ★ client:only="react" 필수 — window/ResizeObserver 사용 컴포넌트 -->
  <TempleScrollHero
    client:only="react"
    images={heroImages}
    introTitle="실천으로 밝히는 정토사회의 길"
    introSubtitle="스크롤하여 탐색하세요"
    arcTitle="수행과 실천, 30년의 여정"
    arcDesc="1992년 창립부터 2026년 현재까지, 한국 불교 개혁의 중심"
    cardLinks={cardLinks}
    cardLabels={cardLabels}
    bgClass="bg-amber-50/40"
  />

  <!-- Hero 아래 본문 — 스크롤 트랩 해제 후 자연스럽게 진입 -->
  <main>
    <section class="py-20 bg-white">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold text-stone-900 mb-4" style="font-family: 'Noto Serif KR', serif;">
          승가의 목소리
        </h2>
        <p class="text-stone-500">최신 성명서와 활동 소식을 확인하세요.</p>
      </div>
    </section>
  </main>
</Layout>
