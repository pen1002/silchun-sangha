 *
 * ⚠ 반드시 client:only="react" 사용 (SSR 불가 컴포넌트)
 */
import Layout from "../layouts/Layout.astro";
import TempleScrollHero from "../components/TempleScrollHero";

// ── 갤러리 이미지 (Cloudinary 또는 로컬) ──
const heroImages = [
  "/images/gallery/temple-01.jpg",
  "/images/gallery/temple-02.jpg",
  "/images/gallery/temple-03.jpg",
  "/images/gallery/temple-04.jpg",
  "/images/gallery/temple-05.jpg",
  "/images/gallery/temple-06.jpg",
  "/images/gallery/temple-07.jpg",
  "/images/gallery/temple-08.jpg",
  "/images/gallery/temple-09.jpg",
  "/images/gallery/temple-10.jpg",
  "/images/gallery/temple-11.jpg",
  "/images/gallery/temple-12.jpg",
  "/images/gallery/temple-13.jpg",
  "/images/gallery/temple-14.jpg",
  "/images/gallery/temple-15.jpg",
  "/images/gallery/temple-16.jpg",
];

// ── 각 카드별 링크 & 라벨 매핑 ──
const cardLinks: Record<number, string> = {
  0: "/about",
  1: "/news",
  2: "/activities",
  3: "/participate",
  4: "/archive",
  5: "/studio/slides",
  6: "/studio/quiz",
  7: "/studio/qna",
  8: "/studio/flashcards",
  9: "/studio/mindmaps",
  10: "/studio/infographic",
  11: "/studio/reports",
  12: "/studio/data-tables",
  13: "/donate",
  14: "/register",
  15: "/contact",
};

const cardLabels: Record<number, string> = {
  0: "승가회 소개",
  1: "소식",
  2: "실천 활동",
  3: "연대와 참여",
  4: "아카이브",
  5: "슬라이드",
  6: "퀴즈",
  7: "Q&A",
  8: "플래시카드",
  9: "마인드맵",
  10: "인포그래픽",
  11: "보고서",
  12: "데이터 표",
  13: "후원하기",
  14: "회원가입",
  15: "문의",
